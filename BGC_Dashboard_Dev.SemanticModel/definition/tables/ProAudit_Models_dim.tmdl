				    #"Extracted Text Before Delimiter" = Table.TransformColumns(#"Duplicated Column", {{"Model - Copy", each Text.BeforeDelimiter(_, " "), type text}}),
				    #"Renamed Columns2" = Table.RenameColumns(#"Extracted Text Before Delimiter",{{"Model - Copy", "ModelCodeExtract"}, {"Plant", "plant"}}),
