table ProAudit_Models_dim
	lineageTag: e3d9c024-019d-4b0a-b6ba-6ebf1f9e5241

	measure 'Table Rank top10 Note' =
			
			VAR _rank = [Ø QK] + DIVIDE(MAX(ProAudit_Models_dim[index]), 100000)
			VAR _condition = 2 * [QK Target Fulfilment]
			RETURN _rank + _condition
		isHidden
