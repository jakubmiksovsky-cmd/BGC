	column current_week_id = ```
			
			VAR _maxyearweek1 = MAX('Calendar'[YearWeek])
			VAR _maxyearweek2 = _maxyearweek1 - 1
			VAR _maxyearweek3 = _maxyearweek1 - 2
			VAR _maxyearweek4 = _maxyearweek1 - 3
			VAR _maxyearweek5 = _maxyearweek1 - 4
			VAR _maxyearweek6 = _maxyearweek1 - 5
			RETURN 
			    IF('Calendar'[YearWeek] = _maxyearweek1, 1,
			            IF('Calendar'[YearWeek] = _maxyearweek2, 2,
			                IF('Calendar'[YearWeek] = _maxyearweek3, 3,
			                    IF('Calendar'[YearWeek] = _maxyearweek4, 4,
			                        IF('Calendar'[YearWeek] = _maxyearweek5, 5, 6)
			                    )
			                )
			            )
			        )
			```
		formatString: 0
		lineageTag: 3a206656-1dbd-4917-b135-847e97dff18a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition Calendar = m
		mode: import
		source =
				let
				    StartDate = #date(2024, 1, 1),  // Replace with your actual start date if needed
				    CurrentYear = Date.Year(DateTime.LocalNow()),
				    EndDate = #date(CurrentYear, 12, 31),
				    NumberOfDays = Number.From(EndDate) - Number.From(StartDate) + 1,
				    Source = List.Dates(StartDate, NumberOfDays, #duration(1,0,0,0)),
				    #"Converted to Table" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
				    #"Changed Type" = Table.TransformColumnTypes(#"Converted to Table",{{"Column1", type date}}),
				    // Display only dates until today.
				    #"Filtered Rows" = Table.SelectRows(#"Changed Type", each [Column1] <= Date.From(DateTime.LocalNow())),
				    #"Inserted Week of Year" = Table.AddColumn(#"Filtered Rows", "Week", each "CW" & Number.ToText(Date.WeekOfYear([Column1],Day.Friday),"D2")),
				    #"Inserted Year" = Table.AddColumn(#"Inserted Week of Year", "Year", each Date.Year([Column1]), Int64.Type),
				    #"Inserted Day Name" = Table.AddColumn(#"Inserted Year", "Day Name", each Date.DayOfWeekName([Column1], "en-US"), type text),
				    #"Renamed Columns" = Table.RenameColumns(#"Inserted Day Name",{{"Column1", "Date"}}),
				    #"Duplicated Date Column" = Table.DuplicateColumn(#"Renamed Columns", "Date", "Date - Copy"),
				    #"Changed Type for Copy" = Table.TransformColumnTypes(#"Duplicated Date Column",{{"Date - Copy", type date}}),
				    #"Added YearWeek" = Table.AddColumn(#"Changed Type for Copy", "YearWeek", each Number.ToText([Year]) & Number.ToText(Date.WeekOfYear([Date],Day.Friday),"D2")),
				    #"Reordered Columns" = Table.ReorderColumns(#"Added YearWeek",{"Date", "Week", "YearWeek", "Year", "Day Name", "Date - Copy"}),
				    #"Changed YearWeek Type" = Table.TransformColumnTypes(#"Reordered Columns",{{"YearWeek", Int64.Type}}),
				    #"Added YearMonth" = Table.AddColumn(#"Changed YearWeek Type", "YearMonth", each Number.ToText([Year]) & Number.ToText(Date.Month([Date]),"D2")),
				    #"Changed YearMonth Type" = Table.TransformColumnTypes(#"Added YearMonth",{{"YearMonth", Int64.Type}}),
				    #"Added YearMonthName" = Table.AddColumn(#"Changed YearMonth Type", "YearMonthName", each Number.ToText([Year]) & "/" & Number.ToText(Date.Month([Date]),"D2")),
				    #"Added WeekYear2" = Table.AddColumn(#"Added YearMonthName", "WeekYear2", each "CW " & Number.ToText(Date.WeekOfYear([Date],Day.Friday),"D2") & "/" & Number.ToText([Year])),
				    #"Added Custom" = Table.AddColumn(#"Added WeekYear2", "YearWeek2_DE", each "KW " & Number.ToText(Date.WeekOfYear([Date],Day.Friday),"D2") & "/" & Number.ToText([Year])),
				    #"Duplicated Week Column 2" = Table.DuplicateColumn(#"Added Custom", "Week", "Week - Copy - Copy"),
				    #"Replaced CW with KW (German)" = Table.ReplaceValue(#"Duplicated Week Column 2","CW","KW",Replacer.ReplaceText,{"Week - Copy - Copy"}),
				    #"Renamed Week Columns" = Table.RenameColumns(#"Replaced CW with KW (German)",{{"Week - Copy - Copy", "WeekDE"}}),
				    #"Sorted by Date Desc" = Table.Sort(#"Renamed Week Columns",{{"Date", Order.Descending}}),
				    #"Added FutureDateEval" = Table.AddColumn(#"Sorted by Date Desc", "FutureDateEval", each [Date] > DateTime.Date(DateTime.LocalNow())),
				    #"Added StartOfWeek" = Table.AddColumn(#"Added FutureDateEval", "StartOfWeek", each Date.StartOfWeek([Date], Day.Friday), type date)
				in
				    #"Added StartOfWeek"

	annotation PBI_ResultType = Table

