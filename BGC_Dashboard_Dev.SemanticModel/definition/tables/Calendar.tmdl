		summarizeBy: none
		sourceColumn: WeekYear2
		sortByColumn: YearWeek

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column current_week = ```
			
			VAR _maxyearweek1 = MAX('Calendar'[YearWeek])
			VAR _maxyearweek2 = _maxyearweek1 - 1
			VAR _maxyearweek3 = _maxyearweek1 - 2
			VAR _maxyearweek4 = _maxyearweek1 - 3
			VAR _maxyearweek5 = _maxyearweek1 - 4
			VAR _maxyearweek6 = _maxyearweek1 - 5
			RETURN 
			    IF('Calendar'[YearWeek] = _maxyearweek1, "Current week",
			            IF('Calendar'[YearWeek] = _maxyearweek2, "Last week",
			                IF('Calendar'[YearWeek] = _maxyearweek3, "Week before last",
			                    IF('Calendar'[YearWeek] = _maxyearweek4, "Three weeks ago",
			                        IF('Calendar'[YearWeek] = _maxyearweek5, "Four weeks ago", "Other")
			                    )
			                )
			            )
			        )
			```
		lineageTag: 09efbc66-a5f7-403b-ac07-0d33762067b9
		summarizeBy: none
		sortByColumn: current_week_id

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column current_month = ```
			
			    IF('Calendar'[Date] > TODAY(), "Future Days",
			        IF(EOMONTH(TODAY(), 0) = EOMONTH('Calendar'[Date],0), "Current Month",
			            IF(EOMONTH(TODAY(), -1) = ENDOFMONTH('Calendar'[Date]), "Last Month",
			                IF(EOMONTH(TODAY(), -2) = ENDOFMONTH('Calendar'[Date]), "Month before last", 
			                    "Other")
			            )
			        )
			    )
			
			
			/*
			current_month = 
			VAR _maxyearmonth1 = CALCULATE(MAX('Calendar'[YearMonth]), FILTER('Calendar', NOT 'Calendar'[FutureDateEval]))
			VAR _maxyearmonth2 = CALCULATE(MAX('Calendar'[YearMonth]), FILTER('Calendar', NOT 'Calendar'[FutureDateEval]))-1
			VAR _maxyearmonth3 = CALCULATE(MAX('Calendar'[YearMonth]), FILTER('Calendar', NOT 'Calendar'[FutureDateEval]))-2
			RETURN 
			    IF('Calendar'[FutureDateEval], "Future Days", 
			        IF('Calendar'[YearMonth] = _maxyearmonth1, "Current month",
			            IF('Calendar'[YearMonth] = _maxyearmonth2, "Last month", 
			                IF('Calendar'[YearMonth] = _maxyearmonth3, "Month before last", "Other")
			            )
			        )
			    )
			*/
			```
		lineageTag: 83b04be3-d3ff-48a6-a43d-ebf94dee8f61
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

