	measure 'Model Selection Check' = IF(HASONEVALUE(ProAudit_Models_dim[Model]), 1, 0)
		formatString: 0
		displayFolder: 2 Dynamic Titles
		lineageTag: 97a2eb85-2df9-4e88-935f-41267fa88a32

	measure 'QK Target Fulfilment Dyn' = ```
			
			-- This measure returns a number (0, 1, or 2) to conditionally format a visual.
			-- 0 = Green, 1 = Yellow, 2 = Red
			
			VAR _currentBrand = 
			    SELECTEDVALUE('ProAudit_Models_dim'[group_brand]) -- Get the brand in the current filter context.
			
			VAR _currentQKValue = 
			    [Ø QK]
			
			RETURN
			    SWITCH(
			        _currentBrand,
			        "Volkswagen",
			        // Logic for VW: <0.3 (Green), 0.3-0.4 (Yellow), >0.4 (Red)
			        IF(_currentQKValue < [Target QK] + 0.3, 0,
			            IF(_currentQKValue <= [Target QK] + 0.4, 1, 2)
			        ),
			
			        "Volkswagen NFZ",
			        // Logic for VW Commercial Vehicles: <0.4 (Green), 0.4-0.5 (Yellow), >0.5 (Red)
			        IF(_currentQKValue < [Target QK] + 0.4, 0,
			            IF(_currentQKValue <= [Target QK] + 0.5, 1, 2)
			        ),
			
			        "Skoda",
			        // Logic for Skoda: <0.3 (Green), =0.3 (Yellow), >0.3 (Red)
			        IF(_currentQKValue < [Target QK] + 0.3, 0,
			            IF(_currentQKValue = [Target QK] + 0.3, 1, 2)
			        ),
			
			        "Seat / Cupra",
			        // Logic for Seat/Cupra: <15% (Green), 15%-<30% (Yellow), >=30% (Red)
			        IF(_currentQKValue < [Target QK] * 1.15, 0,
			            IF(_currentQKValue < [Target QK] * 1.3, 1, 2)
			        ),
			
			        -- A default value if the brand is none of the above.
			        0
			    )
			```
		formatString: 0
		displayFolder: 3 Targets
		lineageTag: 888f07f7-b839-47a6-851d-0f0972dfd4b8

	measure 'B,B1 Target Fulfilment Dyn' = ```
			
			-- This measure returns a number (0, 1, or 2) to conditionally format a visual.
			-- 0 = Green, 1 = Yellow, 2 = Red
			
			VAR _currentBrand = 
			    SELECTEDVALUE('ProAudit_Models_dim'[group_brand]) -- Get the brand in the current filter context.
			
			VAR _currentBValue = 
			    [Ø B,B1]
			
			RETURN
			    SWITCH(
			        _currentBrand,
			        "Volkswagen",
			        // Logic for VW: <0.45 (Green), 0.45-0.94 (Yellow), >0.94 (Red)
			        IF(_currentBValue < [Target Ø B] + 0.45, 0,
			            IF(_currentBValue <= [Target Ø B] + 0.94, 1, 2)
			        ),
			
			        "Volkswagen NFZ",
			        // Logic for VW Commercial Vehicles: <0.55 (Green), 0.55-0.95 (Yellow), >0.95 (Red)
			        IF(_currentBValue < [Target Ø B] + 0.55, 0,
			            IF(_currentBValue <= [Target Ø B] + 0.95, 1, 2)
			        ),
			
			        "Skoda",
			        // Logic for Skoda: <0.05 (Green), 0.05-0.14 (Yellow), >0.14 (Red)
			        IF(_currentBValue < [Target Ø B] + 0.05, 0,
			            IF(_currentBValue <= [Target Ø B] + 0.14, 1, 2)
			        ),
			
			        "Seat / Cupra",
			        // Logic for Seat/Cupra: <15% (Green), 15%-<30% (Yellow), >=30% (Red)
			        IF(_currentBValue < [Target Ø B] * 1.15, 0,
			            IF(_currentBValue < [Target Ø B] * 1.30, 1, 2)
			        ),
			
			        -- A default value if the brand is none of the above.
			        0
			    )
			```
		formatString: 0
		displayFolder: 3 Targets
		lineageTag: 9f1e4aae-ed1d-4731-8fb1-7b4fd9514408

