	partition Measures_Table = m
		mode: import
		source =
				let
				Source = #table(type table[Date Last Refreshed=datetime], {{DateTimeZone.FixedUtcNow() + #duration(0,2,0,0)}}),
				    #"Změněný typ s národním prostředím" = Table.TransformColumnTypes(Source, {{"Date Last Refreshed", type datetime}}, "cs-CZ"),
				    #"Removed Columns" = Table.RemoveColumns(#"Změněný typ s národním prostředím",{"Date Last Refreshed"})
				in
				    #"Removed Columns"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

