	measure 'Ø QK (LM)' =
			
			VAR _FirstDateInSelectedWeek =
			    MIN ( 'Calendar'[Date] )
			VAR _LastDateOfPreviousWeek = _FirstDateInSelectedWeek - 1
			VAR _PreviousYearWeek =
			    LOOKUPVALUE (
			        'Calendar'[YearWeek],
			        'Calendar'[Date],
			        _LastDateOfPreviousWeek
			    )
			RETURN
			    CALCULATE (
			        [Ø QK],
			        FILTER ( ALL ( 'Calendar' ), 'Calendar'[YearWeek] = _PreviousYearWeek )
			    )
		formatString: 0.00
		displayFolder: 7 All
		lineageTag: 1a176b47-c7a8-4bee-8477-75ced0f7f424

	measure 'Ø QK (LW)' = ```
			
			VAR _FirstDateInSelectedWeek =
			    MIN ( 'Calendar'[Date] )
			VAR _LastDateOfPreviousWeek = _FirstDateInSelectedWeek - 1
			VAR _PreviousYearWeek =
			    LOOKUPVALUE (
			        'Calendar'[YearWeek],
			        'Calendar'[Date],
			        _LastDateOfPreviousWeek
			    )
			RETURN
			    CALCULATE (
			        [Ø QK],
			        FILTER ( ALL ( 'Calendar' ), 'Calendar'[YearWeek] = _PreviousYearWeek )
			    )
			
			```
		displayFolder: 7 All
		lineageTag: 862d34b9-adcc-4959-9f75-791ddfda7557

		annotation PBI_FormatHint = {"isGeneralNumber":true}

